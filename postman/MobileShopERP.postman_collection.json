{
  "info": {
    "name": "Mobile Shop ERP API",
    "description": "Backend API collection for the Mobile Shop ERP (Phases 0-8). Every request returns the ApiResponse<T> envelope documented in admin/BACKEND_API_CONTRACT.md. Run \"Login\" first — it automatically stores accessToken/refreshToken as collection variables used by every other request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081/api/v1" },
    { "key": "serverUrl", "value": "http://localhost:8081" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "roleId", "value": "1" },
    { "key": "brandId", "value": "1" },
    { "key": "categoryId", "value": "1" },
    { "key": "attributeGroupId", "value": "1" },
    { "key": "attributeId", "value": "1" },
    { "key": "attributeValueId", "value": "1" },
    { "key": "productId", "value": "" },
    { "key": "variantId", "value": "" },
    { "key": "imageId", "value": "" },
    { "key": "priceId", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "supplierId", "value": "" },
    { "key": "purchaseId", "value": "" },
    { "key": "purchaseItemId", "value": "" },
    { "key": "stockId", "value": "" },
    { "key": "saleId", "value": "" },
    { "key": "saleItemId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "repairId", "value": "" },
    { "key": "warrantyId", "value": "" },
    { "key": "expenseId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"9999999999\",\n  \"password\": \"Admin@123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.success) {",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "  pm.collectionVariables.set('userId', body.data.user.id);",
                  "}",
                  "pm.test('Login succeeded', () => body.success === true);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.success) {",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users (paginated)",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/users?page=0&size=20&sort=createdAt,desc", "host": ["{{baseUrl}}"], "path": ["users"], "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "20" }, { "key": "sort", "value": "createdAt,desc" }] } }
        },
        {
          "name": "Get User by Id",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] } }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"roleId\": {{roleId}},\n  \"firstName\": \"Staff\",\n  \"lastName\": \"User\",\n  \"mobile\": \"9000000001\",\n  \"email\": \"staff@example.com\",\n  \"password\": \"Staff@123456\"\n}" },
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Staff\",\n  \"lastName\": \"Updated\",\n  \"active\": true\n}" },
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        },
        {
          "name": "Deactivate User (soft delete)",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] } }
        }
      ]
    },
